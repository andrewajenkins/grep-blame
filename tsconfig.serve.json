{
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,
    "module": "commonjs",
    "target": "ESNext",
    "types": ["node"],
    "lib": ["ESNext", "DOM"]
  },
  "files": ["app/main.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
